{
  "name": "openlogos-website",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "generate:releases": "node scripts/generate-releases.mjs",
    "fetch:fonts": "node scripts/fetch-fonts.mjs",
    "subset:fonts": "node scripts/subset-fonts.mjs",
    "build": "npm run generate:releases && astro build && npm run fetch:fonts && npm run subset:fonts",
    "preview": "astro preview",
    "smoke:releases": "node scripts/smoke-releases.mjs",
    "test": "node --test test/*.test.mjs",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name openlogos"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.2",
    "astro": "^6.1.3"
  }
}
