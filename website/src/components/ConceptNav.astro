---
interface Props {
  current: string;
}

const { current } = Astro.props;

const items = [
  { id: 'three-layer-model', label: 'WHY→WHAT→HOW', href: '/concepts/three-layer-model', color: '#f59e0b' },
  { id: 'scenario-test-first', label: 'Scenario + Test-First', href: '/concepts/scenario-test-first', color: '#10b981' },
  { id: 'documents-as-context', label: 'Documents as Context', href: '/concepts/documents-as-context', color: '#3b82f6' },
  { id: 'engineering-foundation', label: 'Engineering Foundation', href: '/concepts/engineering-foundation', color: '#a855f7' },
];
---

<nav class="concept-nav" aria-label="Concept pages">
  <div class="concept-nav-inner">
    {items.map((item) => (
      <a
        href={item.href}
        class={`concept-nav-item ${item.id === current ? 'active' : ''}`}
        style={item.id === current ? `--nav-accent: ${item.color}` : ''}
      >
        <span class="concept-nav-dot" style={`background: ${item.color}`}></span>
        {item.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .concept-nav {
    position: sticky;
    top: 64px;
    z-index: 50;
    background: rgba(9, 9, 11, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .concept-nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0.5rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .concept-nav-inner::-webkit-scrollbar { display: none; }

  .concept-nav-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.3rem 0.75rem;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;
  }

  .concept-nav-item:hover {
    color: var(--color-text);
    background: var(--color-surface-raised);
  }

  .concept-nav-item.active {
    color: var(--color-text);
    background: color-mix(in srgb, var(--nav-accent, #6366f1) 15%, var(--color-surface));
    border: 1px solid color-mix(in srgb, var(--nav-accent, #6366f1) 30%, transparent);
    font-weight: 600;
    box-shadow: 0 0 8px color-mix(in srgb, var(--nav-accent, transparent) 15%, transparent);
  }

  .concept-nav-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    opacity: 0.6;
  }

  .concept-nav-item.active .concept-nav-dot {
    opacity: 1;
  }
</style>
