---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="RunLogos — The Best-Practice Tool for OpenLogos | openlogos.ai"
  description="OpenLogos defines the standards. RunLogos makes them land better. Visualize, edit, orchestrate, and debug everything AI generates — all in one desktop app."
>

<!-- Hero -->
<section class="rl-hero">
  <div class="container">
    <div class="rl-hero-tag">OpenLogos + RunLogos</div>
    <h1>OpenLogos Defines the Standards.<br/><span class="accent">RunLogos Makes Them Land Better.</span></h1>
    <p class="rl-hero-desc">
      OpenLogos works standalone with any AI coding tool. RunLogos amplifies it —
      visualize, edit, orchestrate, and debug everything AI generates, all in one desktop app.
    </p>
    <p class="rl-hero-sub">The methodology is free and open source. Professional tools available in Community and Enterprise editions.</p>
    <div class="rl-hero-actions">
      <a href="/" class="btn-ghost">Learn OpenLogos</a>
      <a href="https://runlogos.com" target="_blank" rel="noopener" class="btn-primary">
        Visit RunLogos
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4.5 11.5l7-7M4.5 4.5h7v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
  <div class="rl-hero-glow"></div>
</section>

<!-- Relationship -->
<section class="rl-relationship">
  <div class="container">
    <div class="section-label">THE RELATIONSHIP</div>
    <h2>Why Two Products?</h2>
    <p class="section-desc">A proven model: open standards drive adoption, professional tools drive productivity.</p>

    <div class="rl-compare-grid">
      <div class="rl-compare-card">
        <div class="rl-compare-badge open">Open Source</div>
        <h3>OpenLogos</h3>
        <p class="rl-compare-role">The Methodology</p>
        <ul>
          <li>AI Skills that guide structured development</li>
          <li>Specifications for project structure &amp; workflow</li>
          <li>CLI tools for initialization &amp; verification</li>
          <li>Works with Cursor, Claude Code, OpenCode</li>
        </ul>
        <div class="rl-compare-price">Free &amp; Open Source (Apache 2.0)</div>
      </div>
      <div class="rl-compare-card featured">
        <div class="rl-compare-badge pro">Professional Tool</div>
        <h3>RunLogos</h3>
        <p class="rl-compare-role">The Best-Practice Desktop App</p>
        <ul>
          <li>Visual viewers &amp; editors for all AI-generated docs</li>
          <li>API orchestration runner &amp; debugger</li>
          <li>Comment-to-Prompt AI communication</li>
          <li>Change management &amp; test result dashboard</li>
        </ul>
        <div class="rl-compare-price">Community (Free) &middot; Pro ($49)</div>
      </div>
    </div>

    <div class="rl-precedents">
      <div class="rl-precedents-label">Industry Precedents</div>
      <div class="rl-precedents-grid">
        <div class="rl-precedent"><span class="open-tag">OpenAPI</span><span class="arrow">&rarr;</span><span class="tool-tag">SwaggerHub</span></div>
        <div class="rl-precedent"><span class="open-tag">Kubernetes</span><span class="arrow">&rarr;</span><span class="tool-tag">OpenShift</span></div>
        <div class="rl-precedent"><span class="open-tag">Scrum / Agile</span><span class="arrow">&rarr;</span><span class="tool-tag">Jira / Linear</span></div>
        <div class="rl-precedent"><span class="open-tag">GraphQL</span><span class="arrow">&rarr;</span><span class="tool-tag">Apollo Studio</span></div>
      </div>
    </div>
  </div>
</section>

<!-- Core Capabilities -->
<section class="rl-capabilities">
  <div class="container">
    <div class="section-label">CORE CAPABILITIES</div>
    <h2>Everything AI Generates, Visualized &amp; Editable</h2>
    <p class="section-desc">RunLogos transforms raw AI output into an interactive, visual workspace.</p>

    <!-- Capability 1: Visual Document Viewer & Editor -->
    <div class="rl-capability">
      <div class="rl-cap-header">
        <span class="rl-cap-number">01</span>
        <div>
          <h3>Visual Document Viewer &amp; Editor</h3>
          <p>View and edit all AI-generated documents — Markdown, page prototypes, OpenAPI specs, database schemas, test cases, test results, change proposals, and tasks. OpenAPI and database schemas come with dedicated visual editors supporting SQLite, PostgreSQL, and MySQL.</p>
        </div>
      </div>
      <div class="rl-screenshot-tabs" data-tabs="cap1">
        <div class="rl-tab-nav">
          <button class="rl-tab active" data-target="cap1-md">Markdown Editor</button>
          <button class="rl-tab" data-target="cap1-seq">Sequence Diagrams</button>
          <button class="rl-tab" data-target="cap1-proto">Page Prototypes</button>
          <button class="rl-tab" data-target="cap1-api">OpenAPI Editor</button>
          <button class="rl-tab" data-target="cap1-db">Database Editor</button>
        </div>
        <div class="rl-tab-panels">
          <div class="rl-panel active" id="cap1-md"><img src="/runlogos/1.markdown.editor.jpg" alt="RunLogos Markdown Editor" loading="lazy" /></div>
          <div class="rl-panel" id="cap1-seq"><img src="/runlogos/1.1.markdown.sequence.viewer.jpg" alt="RunLogos Sequence Diagram Viewer" loading="lazy" /></div>
          <div class="rl-panel" id="cap1-proto"><img src="/runlogos/2.typeproto.viewer.jpg" alt="RunLogos Page Prototype Viewer" loading="lazy" /></div>
          <div class="rl-panel" id="cap1-api"><img src="/runlogos/3.openapi-editor.jpg" alt="RunLogos OpenAPI Visual Editor" loading="lazy" /></div>
          <div class="rl-panel" id="cap1-db"><img src="/runlogos/4.db-editor(sqllite:postgresql:mysql).jpg" alt="RunLogos Database Editor" loading="lazy" /></div>
        </div>
      </div>
    </div>

    <!-- Capability 2: API Orchestration Runner & Debugger -->
    <div class="rl-capability">
      <div class="rl-cap-header">
        <span class="rl-cap-number">02</span>
        <div>
          <h3>API Orchestration Runner &amp; Debugger</h3>
          <p>Execute AI-written API orchestration test scenarios directly. Inspect every API call's request and response in detail. Visually modify orchestration definitions — making scenario testing truly WYSIWYG.</p>
        </div>
      </div>
      <div class="rl-screenshot-tabs" data-tabs="cap2">
        <div class="rl-tab-nav">
          <button class="rl-tab active" data-target="cap2-debug">API Debugger</button>
          <button class="rl-tab" data-target="cap2-orch">Orchestration Runner</button>
        </div>
        <div class="rl-tab-panels">
          <div class="rl-panel active" id="cap2-debug"><img src="/runlogos/5.api.debug.jpg" alt="RunLogos API Debugger" loading="lazy" /></div>
          <div class="rl-panel" id="cap2-orch"><img src="/runlogos/6.api.orchestration.and.run.and.debug.jpg" alt="RunLogos API Orchestration Runner" loading="lazy" /></div>
        </div>
      </div>
    </div>

    <!-- Capability 3: Comment-to-Prompt -->
    <div class="rl-capability">
      <div class="rl-cap-header">
        <span class="rl-cap-number">03</span>
        <div>
          <h3>Comment-to-Prompt AI Communication</h3>
          <p>Highlight any text in a document, leave inline comments, then generate a precise AI prompt from multiple comments. Go from vague feedback to exact instructions — dramatically improving AI collaboration efficiency.</p>
        </div>
      </div>
      <div class="rl-screenshot-tabs" data-tabs="cap3">
        <div class="rl-tab-nav">
          <button class="rl-tab active" data-target="cap3-comment">Inline Comments</button>
          <button class="rl-tab" data-target="cap3-prompt">Generate AI Prompt</button>
        </div>
        <div class="rl-tab-panels">
          <div class="rl-panel active" id="cap3-comment"><img src="/runlogos/1.2.markdown.comments.to.prompt.1.jpg" alt="RunLogos Inline Comments" loading="lazy" /></div>
          <div class="rl-panel" id="cap3-prompt"><img src="/runlogos/1.2.markdown.comments.to.prompt.2.jpg" alt="RunLogos Comment-to-Prompt" loading="lazy" /></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Workflow -->
<section class="rl-workflow">
  <div class="container">
    <div class="section-label">COLLABORATION LOOP</div>
    <h2>How OpenLogos + RunLogos Work Together</h2>
    <p class="section-desc">A complete closed-loop from methodology to tool to AI and back.</p>

    <div class="rl-workflow-steps">
      <div class="rl-step">
        <div class="rl-step-num">1</div>
        <div class="rl-step-content">
          <h4>Methodology-Driven</h4>
          <p>Use OpenLogos Skills in your AI coding tool to complete the full Requirements &rarr; Design &rarr; Code workflow.</p>
        </div>
      </div>
      <div class="rl-step-arrow">&darr;</div>
      <div class="rl-step">
        <div class="rl-step-num">2</div>
        <div class="rl-step-content">
          <h4>Visualize &amp; Edit</h4>
          <p>All AI-generated documents (PRD, API, DB, test cases) are rendered visually in RunLogos with full editing support.</p>
        </div>
      </div>
      <div class="rl-step-arrow">&darr;</div>
      <div class="rl-step">
        <div class="rl-step-num">3</div>
        <div class="rl-step-content">
          <h4>Orchestrate &amp; Test</h4>
          <p>Run API orchestration scenarios in RunLogos to validate business flows with detailed request/response inspection.</p>
        </div>
      </div>
      <div class="rl-step-arrow">&darr;</div>
      <div class="rl-step">
        <div class="rl-step-num">4</div>
        <div class="rl-step-content">
          <h4>Precise Feedback</h4>
          <p>Use comment-to-prompt to turn review notes into precise AI instructions — no more vague descriptions.</p>
        </div>
      </div>
      <div class="rl-step-arrow">&darr;</div>
      <div class="rl-step">
        <div class="rl-step-num">5</div>
        <div class="rl-step-content">
          <h4>Closed-Loop Iteration</h4>
          <p>Methodology &rarr; Tool &rarr; AI &rarr; Methodology. Each cycle delivers higher quality with less effort.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Pricing Tiers -->
<section class="rl-tiers">
  <div class="container">
    <div class="section-label">CHOOSE YOUR PATH</div>
    <h2>Start Free, Scale When Ready</h2>

    <div class="rl-tiers-grid">
      <div class="rl-tier">
        <h3>OpenLogos</h3>
        <div class="rl-tier-price">Free</div>
        <p>AI Skills + Specifications + CLI. Works with Cursor, Claude Code, and more. Full methodology, zero cost.</p>
        <a href="/getting-started/quick-start" class="btn-ghost">Get Started</a>
      </div>
      <div class="rl-tier">
        <h3>RunLogos Community</h3>
        <div class="rl-tier-price">Free</div>
        <p>Basic document viewer and project management. A solid foundation for exploring the OpenLogos workflow visually.</p>
        <a href="https://runlogos.com" target="_blank" rel="noopener" class="btn-ghost">Download</a>
      </div>
      <div class="rl-tier featured">
        <h3>RunLogos Pro</h3>
        <div class="rl-tier-price">$49 <span>one-time purchase</span></div>
        <p>Visual editors, API orchestration, comment-to-prompt, and more. The full power of RunLogos, buy once and own forever.</p>
        <a href="https://runlogos.com" target="_blank" rel="noopener" class="btn-primary">Learn More</a>
      </div>
    </div>
  </div>
</section>

<!-- Bottom CTA -->
<section class="rl-cta">
  <div class="container">
    <h2>Ready to Build Right?</h2>
    <p>Start with OpenLogos methodology today. Add RunLogos when you're ready for 10x productivity.</p>
    <div class="rl-cta-actions">
      <a href="/getting-started/quick-start" class="btn-primary">Get Started with OpenLogos</a>
      <a href="https://runlogos.com" target="_blank" rel="noopener" class="btn-ghost">
        Explore RunLogos
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M4.5 11.5l7-7M4.5 4.5h7v7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
  // Tab switching for screenshot panels
  document.querySelectorAll('.rl-screenshot-tabs').forEach(tabGroup => {
    const buttons = tabGroup.querySelectorAll('.rl-tab');
    const panels = tabGroup.querySelectorAll('.rl-panel');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-target');
        buttons.forEach(b => b.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById(target!)?.classList.add('active');
      });
    });
  });
</script>

</BaseLayout>

<style>
  .container { max-width: var(--max-width); margin: 0 auto; padding: 0 1.5rem; }
  .section-label { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-primary); margin-bottom: 0.75rem; }
  .section-desc { color: var(--color-text-muted); font-size: 0.95rem; max-width: 640px; margin: 0.5rem auto 0; line-height: 1.7; }
  h2 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; letter-spacing: -0.03em; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.75rem 1.5rem; background: var(--color-primary); color: white;
    border-radius: 10px; font-weight: 600; font-size: 0.9rem;
    box-shadow: 0 0 20px var(--color-primary-glow);
    transition: background 0.2s, transform 0.2s;
  }
  .btn-primary:hover { background: var(--color-primary-hover); color: white; transform: translateY(-1px); }
  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.75rem 1.5rem; background: var(--color-surface); color: var(--color-text);
    border: 1px solid var(--color-border); border-radius: 10px;
    font-weight: 600; font-size: 0.9rem; transition: border-color 0.2s, transform 0.2s;
  }
  .btn-ghost:hover { border-color: var(--color-border-hover); color: var(--color-text); transform: translateY(-1px); }

  /* Hero */
  .rl-hero { position: relative; padding: 9rem 1.5rem 5rem; text-align: center; overflow: hidden; }
  .rl-hero-tag { display: inline-block; padding: 0.35rem 1rem; background: var(--color-surface-raised); border: 1px solid var(--color-border); border-radius: 100px; font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); letter-spacing: 0.05em; margin-bottom: 1.5rem; }
  .rl-hero h1 { font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1.15; max-width: 800px; margin: 0 auto; }
  .rl-hero .accent { background: linear-gradient(135deg, #0eb677 0%, #2dd4bf 50%, #34d399 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .rl-hero-desc { color: var(--color-text-secondary); font-size: 1.05rem; max-width: 640px; margin: 1.25rem auto 0; line-height: 1.7; }
  .rl-hero-sub { color: var(--color-text-muted); font-size: 0.85rem; margin-top: 0.75rem; }
  .rl-hero-actions { display: flex; gap: 0.75rem; justify-content: center; margin-top: 2rem; flex-wrap: wrap; }
  .rl-hero-glow { position: absolute; bottom: -40%; left: 50%; transform: translateX(-50%); width: 600px; height: 400px; background: radial-gradient(ellipse, var(--color-primary-glow) 0%, transparent 70%); pointer-events: none; }

  /* Relationship */
  .rl-relationship { padding: 6rem 0; text-align: center; }
  .rl-compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-top: 3rem; text-align: left; }
  .rl-compare-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 14px; padding: 2rem; transition: border-color 0.2s; }
  .rl-compare-card:hover { border-color: var(--color-border-hover); }
  .rl-compare-card.featured { border-color: var(--color-primary); box-shadow: 0 0 30px var(--color-primary-glow); }
  .rl-compare-badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 6px; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1rem; }
  .rl-compare-badge.open { background: rgba(16, 185, 129, 0.12); color: #10b981; }
  .rl-compare-badge.pro { background: rgba(14, 182, 119, 0.15); color: #0eb677; }
  .rl-compare-card h3 { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.02em; }
  .rl-compare-role { color: var(--color-text-muted); font-size: 0.85rem; margin-top: 0.25rem; margin-bottom: 1.25rem; }
  .rl-compare-card ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .rl-compare-card li { font-size: 0.88rem; color: var(--color-text-secondary); padding-left: 1.25rem; position: relative; line-height: 1.5; }
  .rl-compare-card li::before { content: ''; position: absolute; left: 0; top: 0.55rem; width: 6px; height: 6px; border-radius: 50%; background: var(--color-primary); }
  .rl-compare-price { margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--color-border); font-size: 0.82rem; font-weight: 600; color: var(--color-text-muted); }

  .rl-precedents { margin-top: 3rem; }
  .rl-precedents-label { font-size: 0.72rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; }
  .rl-precedents-grid { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; }
  .rl-precedent { display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; }
  .open-tag { color: var(--color-text-secondary); background: var(--color-surface); padding: 0.3rem 0.7rem; border-radius: 6px; border: 1px solid var(--color-border); }
  .arrow { color: var(--color-text-muted); }
  .tool-tag { color: var(--color-primary); background: rgba(14, 182, 119, 0.08); padding: 0.3rem 0.7rem; border-radius: 6px; border: 1px solid rgba(14, 182, 119, 0.2); }

  /* Capabilities */
  .rl-capabilities { padding: 6rem 0; text-align: center; }
  .rl-capability { margin-top: 4rem; text-align: left; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 16px; padding: 2.5rem; }
  .rl-cap-header { display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 2rem; }
  .rl-cap-number { font-size: 2rem; font-weight: 900; color: var(--color-primary); opacity: 0.4; line-height: 1; flex-shrink: 0; min-width: 2.5rem; }
  .rl-cap-header h3 { font-size: 1.25rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.5rem; }
  .rl-cap-header p { font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.6; }

  /* Screenshot Tabs */
  .rl-tab-nav { display: flex; gap: 0.25rem; overflow-x: auto; padding-bottom: 0.5rem; margin-bottom: 1rem; border-bottom: 1px solid var(--color-border); }
  .rl-tab { background: none; border: none; color: var(--color-text-muted); font-family: var(--font-sans); font-size: 0.78rem; font-weight: 500; padding: 0.5rem 0.875rem; border-radius: 8px 8px 0 0; cursor: pointer; transition: color 0.15s, background 0.15s; white-space: nowrap; border-bottom: 2px solid transparent; }
  .rl-tab:hover { color: var(--color-text-secondary); }
  .rl-tab.active { color: var(--color-primary); border-bottom-color: var(--color-primary); background: rgba(14, 182, 119, 0.05); }
  .rl-panel { display: none; }
  .rl-panel.active { display: block; }
  .rl-panel img { width: 100%; border-radius: 10px; border: 1px solid var(--color-border); }

  /* Workflow */
  .rl-workflow { padding: 6rem 0; text-align: center; }
  .rl-workflow-steps { max-width: 560px; margin: 3rem auto 0; text-align: left; }
  .rl-step { display: flex; gap: 1.25rem; align-items: flex-start; }
  .rl-step-num { width: 36px; height: 36px; border-radius: 10px; background: var(--color-surface-raised); border: 1px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 0.82rem; font-weight: 700; color: var(--color-primary); flex-shrink: 0; }
  .rl-step-content h4 { font-size: 1rem; font-weight: 700; margin-bottom: 0.25rem; }
  .rl-step-content p { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.6; }
  .rl-step-arrow { text-align: center; color: var(--color-border-hover); font-size: 1.25rem; padding: 0.25rem 0 0.25rem 1rem; }

  /* Tiers */
  .rl-tiers { padding: 6rem 0; text-align: center; }
  .rl-tiers-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-top: 3rem; text-align: left; }
  .rl-tier { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 14px; padding: 2rem; display: flex; flex-direction: column; transition: border-color 0.2s; }
  .rl-tier:hover { border-color: var(--color-border-hover); }
  .rl-tier.featured { border-color: var(--color-primary); box-shadow: 0 0 30px var(--color-primary-glow); }
  .rl-tier h3 { font-size: 1.15rem; font-weight: 700; }
  .rl-tier-price { font-size: 1.75rem; font-weight: 900; margin: 0.5rem 0 1rem; letter-spacing: -0.03em; }
  .rl-tier-price span { font-size: 0.75rem; font-weight: 500; color: var(--color-text-muted); }
  .rl-tier p { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.6; flex: 1; margin-bottom: 1.5rem; }
  .rl-tier .btn-primary, .rl-tier .btn-ghost { width: 100%; justify-content: center; }

  /* CTA */
  .rl-cta { padding: 6rem 0 7rem; text-align: center; position: relative; }
  .rl-cta h2 { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; }
  .rl-cta p { color: var(--color-text-muted); font-size: 0.95rem; margin: 0.75rem 0 2rem; }
  .rl-cta-actions { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

  /* Responsive */
  @media (max-width: 768px) {
    .rl-hero { padding: 7rem 1.5rem 4rem; }
    .rl-hero h1 { font-size: clamp(1.75rem, 5vw, 2.5rem); }
    .rl-compare-grid { grid-template-columns: 1fr; }
    .rl-tiers-grid { grid-template-columns: 1fr; }
    .rl-cap-header { flex-direction: column; gap: 0.75rem; }
    .rl-capability { padding: 1.5rem; }
    .rl-tab-nav { gap: 0; }
    .rl-precedents-grid { flex-direction: column; align-items: center; }
  }
</style>
