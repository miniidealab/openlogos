            <div class="prop-chain-col"><span class="prop-tag skip">Req</span><span class="prop-arrow">→</span><span class="prop-tag skip">Design</span><span class="prop-arrow">→</span><span class="prop-tag skip">Scenario</span><span class="prop-arrow">→</span><span class="prop-tag active">API/DB</span><span class="prop-arrow">→</span><span class="prop-tag active">Test</span><span class="prop-arrow">→</span><span class="prop-tag active">Code</span></div>
          </div>
