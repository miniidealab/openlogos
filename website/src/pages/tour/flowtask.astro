<BaseLayout title="FlowTask · Claude Code Workflow — OpenLogos Tour" description="See how a Tauri desktop app was built from requirements to verified code using OpenLogos + Claude Code.">
  <TourNav current="flowtask" />

  <section class="page-hero">
    <div class="container">
      <div class="hero-badge badge-claude">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Claude Code Workflow
      </div>
