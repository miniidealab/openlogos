        <span class="tech-tag">Tauri 2</span>
        <span class="tech-tag">React 18</span>
        <span class="tech-tag">Rust</span>
        <span class="tech-tag">SQLite</span>
        <span class="tech-tag">TypeScript</span>
        <span class="tech-tag">Zustand</span>
      </div>
      <div class="hero-stats">
        <div class="stat"><span class="stat-num">4</span> Scenarios</div>
        <div class="stat-sep">·</div>
        <div class="stat"><span class="stat-num">18</span> Test Cases</div>
        <div class="stat-sep">·</div>
        <div class="stat"><span class="stat-num">100%</span> Coverage</div>
        <div class="stat-sep">·</div>
        <div class="stat pass">Gate 3.5: PASS</div>
