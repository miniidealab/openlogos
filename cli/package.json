{
  "name": "@miniidealab/openlogos",
  "version": "0.5.0",
  "description": "CLI tool for the OpenLogos software engineering methodology",
  "type": "module",
  "bin": {
    "openlogos": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build && node -e \"require('fs').cpSync('../skills','./skills',{recursive:true})\"",
    "postpack": "node -e \"require('fs').rmSync('./skills',{recursive:true,force:true})\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "openlogos",
    "software-engineering",
    "methodology",
    "ai",
    "cli"
  ],
  "author": "MiniIdea",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://openlogos.ai",
  "bugs": {
    "url": "https://github.com/miniidealab/openlogos/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miniidealab/openlogos.git",
    "directory": "cli"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "skills"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4"
  }
}
