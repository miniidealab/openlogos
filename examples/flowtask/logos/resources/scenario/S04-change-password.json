{
  "scenario": "S04",
  "title": "用户修改账号密码",
  "domain": "auth",
  "external_dependencies": [],
  "orchestrations": [

    {
      "id": "OT-S04-01",
      "title": "正常路径：修改密码成功",
      "source": "ST-S04-01",
      "preconditions": ["已有账号 username='xiaoli', password='Pass1234'"],
      "teardown": "UPDATE users SET password = bcrypt('Pass1234') WHERE username='xiaoli'",
      "steps": [
        {
          "seq": 1,
          "step": "login 获取 user_id",
          "command": "login",
          "params": { "username": "xiaoli", "password": "Pass1234" },
          "expected_ok": true,
          "extract": { "user_id": "result.user_id" }
        },
        {
          "seq": 2,
          "step": "S04 Step 5-12: change_password",
          "command": "change_password",
          "params": {
            "user_id": "{{user_id}}",
            "current_password": "Pass1234",
            "new_password": "NewPass99"
          },
          "expected_ok": true,
          "assert": "result.success === true"
        },
        {
          "seq": 3,
          "step": "用新密码登录验证密码已更新",
          "command": "login",
          "params": { "username": "xiaoli", "password": "NewPass99" },
          "expected_ok": true,
          "assert": "result.user_id === {{user_id}}"
        },
        {
          "seq": 4,
          "step": "用旧密码登录应失败",
          "command": "login",
          "params": { "username": "xiaoli", "password": "Pass1234" },
          "expected_ok": false,
          "expected_error": { "code": "INVALID_CREDENTIALS" }
        }
      ]
    },

    {
      "id": "OT-S04-02",
      "title": "异常路径：当前密码错误（EX-8.1）",
      "source": "ST-S04-08",
      "preconditions": ["已有账号 username='xiaoli', password='Pass1234'"],
      "steps": [
        {
          "seq": 1,
          "step": "login 获取 user_id",
          "command": "login",
          "params": { "username": "xiaoli", "password": "Pass1234" },
          "expected_ok": true,
          "extract": { "user_id": "result.user_id" }
        },
        {
          "seq": 2,
          "step": "S04 Step 8: change_password 当前密码错误",
          "command": "change_password",
          "params": {
            "user_id": "{{user_id}}",
            "current_password": "WrongPass",
            "new_password": "NewPass99"
          },
          "expected_ok": false,
          "expected_error": {
            "code": "WRONG_PASSWORD",
            "message": "当前密码不正确"
          }
        },
        {
          "seq": 3,
          "step": "验证密码未被修改（旧密码仍有效）",
          "command": "login",
          "params": { "username": "xiaoli", "password": "Pass1234" },
          "expected_ok": true
        }
      ]
    },

    {
      "id": "OT-S04-03",
      "title": "边界用例：新密码恰好 8 位（下边界 UT-S04-02）",
      "source": "UT-S04-02",
      "preconditions": ["已有账号 username='xiaoli', password='Pass1234'"],
      "teardown": "UPDATE users SET password = bcrypt('Pass1234') WHERE username='xiaoli'",
      "steps": [
        {
          "seq": 1,
          "step": "login 获取 user_id",
          "command": "login",
          "params": { "username": "xiaoli", "password": "Pass1234" },
          "expected_ok": true,
          "extract": { "user_id": "result.user_id" }
        },
        {
          "seq": 2,
          "step": "change_password 新密码 8 位",
          "command": "change_password",
          "params": {
            "user_id": "{{user_id}}",
            "current_password": "Pass1234",
            "new_password": "Abcd1234"
          },
          "expected_ok": true,
          "assert": "result.success === true"
        }
      ]
    },

    {
      "id": "OT-S04-04",
      "title": "边界用例：新密码 7 位应被客户端拦截（EX-4.2，不调用后端）",
      "source": "EX-4.2",
      "preconditions": [],
      "note": "此用例为纯前端校验，不产生 invoke 调用，由 UI 测试覆盖",
      "steps": [
        {
          "seq": 1,
          "step": "前端校验：新密码 7 位",
          "frontend_only": true,
          "input": {
            "current_password": "Pass1234",
            "new_password": "Short12",
            "confirm_password": "Short12"
          },
          "expected_error_field": "newPw",
          "expected_error_message": "密码至少需要 8 位字符"
        }
      ]
    },

    {
      "id": "OT-S04-05",
      "title": "边界用例：新旧密码相同应被客户端拦截（EX-4.3）",
      "source": "EX-4.3",
      "preconditions": [],
      "note": "纯前端校验，不产生 invoke 调用",
      "steps": [
        {
          "seq": 1,
          "step": "前端校验：新旧密码相同",
          "frontend_only": true,
          "input": {
            "current_password": "Pass1234",
            "new_password": "Pass1234",
            "confirm_password": "Pass1234"
          },
          "expected_error_field": "newPw",
          "expected_error_message": "新密码不能与当前密码相同"
        }
      ]
    },

    {
      "id": "OT-S04-06",
      "title": "边界用例：两次新密码不一致应被客户端拦截（EX-4.4）",
      "source": "EX-4.4",
      "preconditions": [],
      "note": "纯前端校验，不产生 invoke 调用",
      "steps": [
        {
          "seq": 1,
          "step": "前端校验：两次新密码不一致",
          "frontend_only": true,
          "input": {
            "current_password": "Pass1234",
            "new_password": "NewPass99",
            "confirm_password": "NewPass00"
          },
          "expected_error_field": "confirmPw",
          "expected_error_message": "两次输入的密码不一致"
        }
      ]
    },

    {
      "id": "OT-S04-07",
      "title": "正常路径：修改密码后会话保持不变（UT-S04-05）",
      "source": "UT-S04-05",
      "preconditions": ["已有账号 username='xiaoli', password='Pass1234'"],
      "teardown": "UPDATE users SET password = bcrypt('Pass1234') WHERE username='xiaoli'",
      "steps": [
        {
          "seq": 1,
          "step": "login 获取 user_id",
          "command": "login",
          "params": { "username": "xiaoli", "password": "Pass1234" },
          "expected_ok": true,
          "extract": { "user_id": "result.user_id" }
        },
        {
          "seq": 2,
          "step": "change_password",
          "command": "change_password",
          "params": {
            "user_id": "{{user_id}}",
            "current_password": "Pass1234",
            "new_password": "NewPass99"
          },
          "expected_ok": true
        },
        {
          "seq": 3,
          "step": "验证 user_id 不变（会话未失效）",
          "note": "Zustand store 中 currentUser.user_id 应与修改前相同，此处通过 DB 验证用户记录存在",
          "db_assert": {
            "query": "SELECT id FROM users WHERE id = {{user_id}}",
            "assert": "rows.length === 1"
          }
        }
      ]
    }

  ]
}
